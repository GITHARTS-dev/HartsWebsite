# Copy this file to .env.local and fill in your local PostgreSQL details.

# Option A: recommended for local development because passwords can contain
# special characters without URL encoding.
PGHOST=localhost
PGPORT=5432
PGDATABASE=Harts_Website
PGUSER=postgres
PGPASSWORD=your-postgres-password

# Set this to true only when your production PostgreSQL requires SSL.
POSTGRES_SSL=false

# Option B: use this instead of the PG* values above if you prefer one URL.
# If your password contains special characters, URL-encode it first.
# Example: @ becomes %40
# DATABASE_URL=postgresql://postgres:your-password@localhost:5432/Harts_Website

# Microsoft Outlook / Microsoft 365 SMTP settings for contact notifications.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=Mukilan.Jegadeesan@globalharts.com
SMTP_PASS=mUKIL2652004
MAIL_TO=Mukilan.Jegadeesan@globalharts.com
