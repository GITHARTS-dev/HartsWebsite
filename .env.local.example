# Copy this file to .env.local and fill in your credentials

# Gmail address used to SEND emails (e.g. your Gmail account)
SMTP_USER=your-gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to generate one:
# 1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
# 2. Then go to myaccount.google.com → Security → App Passwords
# 3. Select "Mail" + "Windows Computer" → Generate
# 4. Paste the 16-character code below (no spaces)
SMTP_PASS=your-16-char-app-password
