# Copy this file to .env.local and fill in your values. Never commit .env.local to git.

# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Get from dash.cloudflare.com > Turnstile > Add Site — use the Managed challenge type.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key


# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings > API. Use the service_role key — NOT the anon key. Server-side only.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ─── Resend ───────────────────────────────────────────────────────────────────
# resend.com > API Keys. Verify hartsconsulting.com domain in Resend before sending.
RESEND_API_KEY=your-resend-api-key


# ─── Legacy (no longer used by contact form) ──────────────────────────────────
# The variables below have been replaced by Supabase (database) and Resend (email).
# They are kept here for reference only.

# # Option A: PostgreSQL individual vars
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=Harts_Website
# PGUSER=postgres
# PGPASSWORD=your-postgres-password

# # Set to true only when production PostgreSQL requires SSL.
# POSTGRES_SSL=false

# # Option B: single connection URL (URL-encode special characters in passwords, e.g. @ → %40)
# DATABASE_URL=postgresql://postgres:your-password@localhost:5432/Harts_Website

# # Microsoft Outlook / Microsoft 365 SMTP settings for contact notifications.
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@globalharts.com
# SMTP_PASS=your-outlook-or-microsoft-365-smtp-secret
# MAIL_TO=your-email@globalharts.com
